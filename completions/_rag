                export) _rag_cmd_whisper_export ;;
                import) _rag_cmd_whisper_import ;;
                patterns) _rag_cmd_whisper_patterns ;;
                stats) _rag_cmd_whisper_stats ;;
                vocab) _rag_cmd_whisper_vocab ;;
            esac
            ;;
    esac
}

