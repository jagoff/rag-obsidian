_rag_cmd_snapshot() {
    local curcontext="$curcontext" state line
    typeset -A opt_args
    _arguments -C \
        '1: :->subcmd' \
        '*::arg:->args'
    case $state in
        subcmd)
            local -a subcommands
            subcommands=(
                'create:Crear snapshot del estado actual.'
                'list:Listar snapshots en ~/.local/share/obsidian-rag/snapshots/.'
                'restore:Restaurar un snapshot creado con `rag snapshot create`.'
            )
            _describe -t subcommands "rag snapshot subcommand" subcommands
            ;;
        args)
            case $line[1] in
                create) _rag_cmd_snapshot_create ;;
                list) _rag_cmd_snapshot_list ;;
                restore) _rag_cmd_snapshot_restore ;;
            esac
            ;;
    esac
}

