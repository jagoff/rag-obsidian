# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv
venv/
env/

# Test/lint caches (la mayoría auto-ignoran vía .gitignore interno, pero
# belt-and-suspenders por si un tool cambia de default).
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
.coverage.*
htmlcov/

# Claude Code worktree scratch — agents reusan este dir para checkouts
# temporales durante parallel feature work. Regenerable, no versionar.
# EXCEPCIÓN: `.claude/agents/` sí se versiona — definen ownership por
# dominio y protocolo peer, son parte del workflow del repo.
.claude/*
!.claude/agents/
# Pero NO los sub-paquetes genéricos que dropea `claude-flow init` /
# similares (analysis, architecture, browser, consensus, core, custom,
# data, development, devops, documentation, flow-nexus, github, goal,
# optimization, payments, sona, sparc, specialized, sublinear, swarm,
# templates, testing, v3). Esos son agent profiles genéricos del tool,
# NO project-specific — pollutearían el registry rag-* del repo.
.claude/agents/*/

# Tooling runtime artifacts (claude-flow, ruvector, swarm telemetry).
# Regenerables; no aportan al state del repo.
.claude-flow/
.swarm/
ruvector.db

# MCP server config — paths absolutos user-specific (sqlite-vec data-dir).
# Migrar a ${HOME}/... y commitear en otra iteración si se quiere compartir.
.mcp.json

# Secrets — NEVER commit. Patterns cubren .env, .env.local, .env.prod, etc.
.env
.env.*
!.env.example
*.pem
*.key
credentials.json
secrets.json

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo
*~

# macOS
.DS_Store
._*

# Windows/Linux artifacts (por si alguien clona en otra plataforma)
Thumbs.db
Desktop.ini

# Playwright MCP session artifacts + stray screenshots
.playwright-mcp/
ticker-buscando.png
# Local OCR end-to-end scratch captures — used for ad-hoc validation of
# the ocrmac pipeline, never meant to be versioned.
ocr-e2e-*.png

# Local screenshots from playwright iterations during dev
v2-iter*.png
ra-home-current.png

# Stray scratch artifacts en root (screenshots de iteración visual,
# canvas dumps base64, outputs ad-hoc de scripts de testing). El repo
# NO commitea PNGs ni TXT en root — todo lo que es tracked vive bajo
# subdirs (web/static/, docs/, tests/). Si necesitás una imagen
# tracked, ponéla en un subdir explícito.
/*.png
/*.txt
CLAUDE.original.md
.devin/mcp-profiles/inventory.json
.devin/mcp-profiles/.active
.devin/mcp-profiles/.default
.devin/mcp-profiles/**/*.bak-harness-*

# caveman skill (https://github.com/JuliusBrussee/caveman) — installer
# writes universal copies por agente. El plugin global en
# ~/.claude/plugins/marketplaces/caveman ya cubre Claude Code, estas
# copias son redundantes para el repo y no deben commitearse.
/.agents/
/.devin/skills/
/.windsurf/skills/
