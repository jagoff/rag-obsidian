graph TD
    subgraph Surfaces["User/API surfaces"]
        CLI["rag CLI"]
        Web["FastAPI web UI<br/>web/server.py"]
        MCP["obsidian-rag-mcp<br/>stdio"]
        WAUI["WhatsApp app<br/>via bridge"]
    end

    subgraph WebGateway["Web Gateway"]
        Routes["HTTP routes + SSE"]
        Schemas["chat_schemas.py<br/>request contracts"]
        Uploads["chat_uploads.py<br/>file/image handling"]
    end

    subgraph Core["RAG Core"]
        ChatSvc["Chat/Retrieval service<br/>retrieve · multi_retrieve · run_chat_turn"]
        Flags["pipeline_flags.py<br/>adaptive routing · NLI · fast-path"]
        IndexSvc["Indexer<br/>chunking · embeddings · entities · URLs"]
        ETL["Integrations ETL<br/>WA · Gmail · Calendar · Reminders · Chrome · Drive · Finance"]
        Runtime["Runtime scheduler<br/>frequent · nightly · supervisor"]
    end

    subgraph Models["Local model runtime"]
        MLX["MLXBackend<br/>Qwen helper/chat/HQ"]
        Embed["qwen3-embedding<br/>1024d"]
        Rerank["bge-reranker-v2-m3<br/>MPS + fp32"]
        NLI["NLI / LLM judge<br/>optional grounding"]
    end

    subgraph Storage["Local storage"]
        Vault["Obsidian vault<br/>iCloud-local files"]
        Vec[("sqlite-vec<br/>ragvec.db")]
        State[("telemetry/state SQLite<br/>sessions · feedback · behavior")]
        Logs["jsonl legacy logs<br/>queries · ambient · filing · surface"]
        Config["~/.config/obsidian-rag<br/>vaults.json · OAuth tokens"]
    end

    CLI --> ChatSvc
    MCP --> ChatSvc
    Web --> Routes
    Routes --> Schemas
    Routes --> Uploads
    Routes --> ChatSvc
    WAUI --> ETL

    ChatSvc --> Flags
    ChatSvc --> Vec
    ChatSvc --> State
    ChatSvc --> MLX
    ChatSvc --> Embed
    ChatSvc --> Rerank
    ChatSvc --> NLI

    IndexSvc --> Vault
    IndexSvc --> Embed
    IndexSvc --> Vec
    ETL --> Vault
    ETL --> State
    Runtime --> ETL
    Runtime --> IndexSvc

    Uploads --> Vault
    State --> Logs
    Config --> ChatSvc
