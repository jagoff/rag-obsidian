_rag() {
    _rag_cmd "$@"
}

# When sourced directly (not autoloaded from fpath), register and dispatch.
if [[ $zsh_eval_context[-1] == loadautofunc ]]; then
    _rag "$@"
else
    compdef _rag rag
fi
