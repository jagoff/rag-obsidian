#!/usr/bin/env -S uv run --quiet python3
# /// script
# requires-python = ">=3.11"
# dependencies = ["click>=8.1"]
# ///
"""rag-harness — switch entre profiles de MCPs / tools / CLI groups.

Diseño:
- `inventory.json` es el source-of-truth: mirror del `mcpServers` de `~/.claude.json`.
  Se regenera con `rag-harness sync-inventory`.
- `profiles/<name>.json` define qué subset del inventory activar:
    {
      "name": "...",
      "description": "...",
      "mcps": ["obsidian-rag", ...],         # keys del inventory
      "rag_mcp_tools": ["query", ...] | null, # null = todas las tools
      "rag_cli_groups": ["core", ...] | null  # null = todos los grupos
    }
- `rag-harness use <name>` reescribe `~/.claude.json` y `~/.config/devin/config.json`:
  * `mcpServers` queda solo con los keys del profile.
  * Si la entry `obsidian-rag` está en el profile, se le injecta
    `env.RAG_MCP_TOOLS` (CSV) y `env.RAG_CLI_GROUPS` (CSV) cuando aplique.
  * Backup automático de los configs originales (`*.bak.<ts>`).

Después del switch hay que **reabrir la sesión** (Claude Code / Devin)
para que el harness se recompile.
"""

from __future__ import annotations

import json
import os
import shutil
import sys
import time
from pathlib import Path

import click

ROOT = Path(__file__).resolve().parent.parent
PROFILES_DIR = ROOT / "profiles"
INVENTORY = ROOT / "inventory.json"
ACTIVE_FILE = ROOT / ".active"

# Targets que reescribimos
CLAUDE_CONFIG = Path.home() / ".claude.json"
DEVIN_CONFIG = Path.home() / ".config" / "devin" / "config.json"


def _load_json(path: Path) -> dict:
    with path.open() as f:
        return json.load(f)


def _save_json(path: Path, data: dict) -> None:
    tmp = path.with_suffix(path.suffix + ".tmp")
    with tmp.open("w") as f:
        json.dump(data, f, indent=2)
        f.write("\n")
    tmp.replace(path)


def _backup(path: Path) -> Path | None:
    if not path.exists():
        return None
    ts = time.strftime("%Y%m%d-%H%M%S")
    bak = path.with_suffix(path.suffix + f".bak-harness-{ts}")
    shutil.copy2(path, bak)
    return bak


def _list_profiles() -> list[Path]:
    return sorted(PROFILES_DIR.glob("*.json"))


def _read_profile(name: str) -> dict:
    p = PROFILES_DIR / f"{name}.json"
    if not p.exists():
        click.echo(f"profile '{name}' no existe en {PROFILES_DIR}", err=True)
        sys.exit(1)
    return _load_json(p)


def _read_inventory() -> dict:
    if not INVENTORY.exists():
        click.echo(
            f"inventory.json no existe. Corré `rag-harness sync-inventory` primero.",
            err=True,
        )
        sys.exit(1)
    return _load_json(INVENTORY)


def _active_name() -> str | None:
    if ACTIVE_FILE.exists():
        return ACTIVE_FILE.read_text().strip() or None
    return None


def _build_mcp_section(profile: dict, inventory: dict) -> dict:
    """Construye el dict mcpServers a partir del inventory + keys del profile.

    Si el profile incluye `obsidian-rag` y define `rag_mcp_tools` o
    `rag_cli_groups`, los injecta como env vars en la entry correspondiente.
    """
    out: dict[str, dict] = {}
    missing: list[str] = []
    for key in profile["mcps"]:
        if key not in inventory:
            missing.append(key)
            continue
        # Deep copy via json round-trip (no shared refs con el inventory)
        out[key] = json.loads(json.dumps(inventory[key]))

    if missing:
        click.echo(
            f"warning: profile pide {missing} pero no están en inventory.json. "
            f"Se ignoran. Considerá `rag-harness sync-inventory`.",
            err=True,
        )

    # Inyectar env vars en obsidian-rag si corresponde
    if "obsidian-rag" in out:
        env = out["obsidian-rag"].setdefault("env", {})
        tools = profile.get("rag_mcp_tools")
        keep = profile.get("rag_cli_keep")
        terse = profile.get("rag_mcp_terse")
        if tools:
            env["RAG_MCP_TOOLS"] = ",".join(tools)
        else:
            env.pop("RAG_MCP_TOOLS", None)
        if keep:
            env["RAG_CLI_KEEP"] = ",".join(keep)
        else:
            env.pop("RAG_CLI_KEEP", None)
        if terse:
            env["RAG_MCP_TOOLS_TERSE"] = "1"
        else:
            env.pop("RAG_MCP_TOOLS_TERSE", None)

    return out


def _apply_to_target(
    target: Path,
    mcp_section: dict,
    inventory_keys: set[str],
    dry_run: bool,
) -> None:
    """Aplica el profile a un target.

    Importante: solo toca keys que estén en `inventory_keys`. MCPs presentes
    en el target pero ajenos al inventory (ej. `engram`/`mem-vault` específicos
    de Devin) se preservan sin cambios — el harness no los gestiona.
    """
    if not target.exists():
        click.echo(f"  - {target}: no existe (skip)")
        return
    data = _load_json(target)
    current = dict(data.get("mcpServers") or {})

    # Preservar MCPs ajenos al inventory
    untouched = {k: v for k, v in current.items() if k not in inventory_keys}
    new_section = dict(untouched)
    new_section.update(mcp_section)

    before_managed = {k for k in current if k in inventory_keys}
    after_managed = set(mcp_section.keys())
    added = sorted(after_managed - before_managed)
    removed = sorted(before_managed - after_managed)
    preserved = sorted(untouched.keys())

    if dry_run:
        click.echo(f"  - {target}:")
        if added:
            click.echo(f"      + {', '.join(added)}")
        if removed:
            click.echo(f"      - {', '.join(removed)}")
        if preserved:
            click.echo(f"      = (preservados, fuera del inventory) {', '.join(preserved)}")
        if not added and not removed:
            click.echo(f"      (sin cambios en mcpServers gestionados)")
        return

    bak = _backup(target)
    data["mcpServers"] = new_section
    _save_json(target, data)
    click.echo(f"  - {target}: ok (backup: {bak.name if bak else '-'})")


@click.group()
def cli():
    """rag-harness — toggle de MCPs / tools / CLI groups del agente."""


@cli.command("list")
def cmd_list():
    """Lista los profiles disponibles + cuál está activo."""
    active = _active_name()
    click.echo(f"profiles disponibles ({PROFILES_DIR}):")
    for p in _list_profiles():
        prof = _load_json(p)
        marker = " *" if prof["name"] == active else "  "
        desc = prof.get("description", "").split("\n")[0]
        click.echo(f"{marker} {prof['name']:<16} {desc}")
    if active:
        click.echo(f"\nactivo: {active}")
    else:
        click.echo("\nactivo: <ninguno> (config sin tocar por harness)")


@cli.command("show")
@click.argument("name", required=False)
def cmd_show(name: str | None):
    """Muestra el contenido de un profile (default: el activo)."""
    name = name or _active_name()
    if not name:
        click.echo("no hay profile activo. Pasá el nombre o ejecutá `rag-harness use <name>`.", err=True)
        sys.exit(1)
    prof = _read_profile(name)
    click.echo(json.dumps(prof, indent=2))


@cli.command("use")
@click.argument("name")
@click.option("--dry-run", is_flag=True, help="No escribe nada, solo muestra qué cambiaría.")
def cmd_use(name: str, dry_run: bool):
    """Activa un profile (reescribe ~/.claude.json y ~/.config/devin/config.json)."""
    profile = _read_profile(name)
    inventory = _read_inventory()
    mcp_section = _build_mcp_section(profile, inventory)

    click.echo(f"profile '{name}' → {len(mcp_section)} MCPs activos:")
    for k in sorted(mcp_section.keys()):
        click.echo(f"    - {k}")

    rag_env = (mcp_section.get("obsidian-rag") or {}).get("env") or {}
    rag_env_keys = {k: v for k, v in rag_env.items() if k.startswith("RAG_")}
    if rag_env_keys:
        click.echo("\nenv inyectado en obsidian-rag:")
        for k, v in rag_env_keys.items():
            click.echo(f"    {k}={v}")

    inventory_keys = set(inventory.keys())
    click.echo("\nescribiendo:" if not dry_run else "\n[dry-run] cambios:")
    _apply_to_target(CLAUDE_CONFIG, mcp_section, inventory_keys, dry_run)
    _apply_to_target(DEVIN_CONFIG, mcp_section, inventory_keys, dry_run)

    if not dry_run:
        ACTIVE_FILE.write_text(name + "\n")
        click.echo(f"\nactivo: {name}")
        click.echo("→ reabrí la sesión (Claude Code / Devin) para que tome efecto.")


@cli.command("diff")
@click.argument("a")
@click.argument("b")
def cmd_diff(a: str, b: str):
    """Compara dos profiles (qué MCPs/tools/groups difieren)."""
    pa = _read_profile(a)
    pb = _read_profile(b)
    sa, sb = set(pa["mcps"]), set(pb["mcps"])
    only_a = sorted(sa - sb)
    only_b = sorted(sb - sa)
    common = sorted(sa & sb)
    click.echo(f"common ({len(common)}): {', '.join(common) or '-'}")
    click.echo(f"solo {a} ({len(only_a)}): {', '.join(only_a) or '-'}")
    click.echo(f"solo {b} ({len(only_b)}): {', '.join(only_b) or '-'}")
    ta = set(pa.get("rag_mcp_tools") or [])
    tb = set(pb.get("rag_mcp_tools") or [])
    if ta or tb:
        click.echo(f"\nrag_mcp_tools:")
        click.echo(f"  {a}: {sorted(ta) if ta else '<all>'}")
        click.echo(f"  {b}: {sorted(tb) if tb else '<all>'}")
    ga = set(pa.get("rag_cli_keep") or [])
    gb = set(pb.get("rag_cli_keep") or [])
    if ga or gb:
        click.echo(f"\nrag_cli_keep:")
        click.echo(f"  {a}: {sorted(ga) if ga else '<all>'}")
        click.echo(f"  {b}: {sorted(gb) if gb else '<all>'}")


@cli.command("sync-inventory")
def cmd_sync_inventory():
    """Regenera inventory.json desde el ~/.claude.json actual.

    Usalo cuando agregaste un MCP nuevo manualmente y querés que los
    profiles puedan referenciarlo. Hace backup del inventory previo.
    """
    if not CLAUDE_CONFIG.exists():
        click.echo(f"{CLAUDE_CONFIG} no existe", err=True)
        sys.exit(1)
    data = _load_json(CLAUDE_CONFIG)
    mcps = data.get("mcpServers") or {}
    if not mcps:
        click.echo(f"{CLAUDE_CONFIG} no tiene mcpServers", err=True)
        sys.exit(1)
    if INVENTORY.exists():
        _backup(INVENTORY)
    _save_json(INVENTORY, mcps)
    click.echo(f"inventory.json regenerado con {len(mcps)} MCPs:")
    for k in sorted(mcps.keys()):
        click.echo(f"    - {k}")


@cli.command("sync-full")
def cmd_sync_full():
    """Regenera profiles/full.json para que liste todos los MCPs del inventory."""
    inventory = _read_inventory()
    full_path = PROFILES_DIR / "full.json"
    if full_path.exists():
        _backup(full_path)
    keys = sorted(inventory.keys())
    full = {
        "name": "full",
        "description": "Snapshot del set completo. Baseline para restore. Auto-regenerable: `rag-harness sync-full`.",
        "mcps": keys,
        "rag_mcp_tools": None,
        "rag_cli_keep": None,
    }
    _save_json(full_path, full)
    click.echo(f"full.json regenerado con {len(keys)} MCPs.")


@cli.command("restore")
def cmd_restore():
    """Restaura ~/.claude.json y ~/.config/devin/config.json desde el backup más reciente."""
    for target in (CLAUDE_CONFIG, DEVIN_CONFIG):
        if not target.exists():
            continue
        baks = sorted(target.parent.glob(target.name + ".bak-harness-*"))
        if not baks:
            click.echo(f"  - {target}: sin backups, skip")
            continue
        latest = baks[-1]
        shutil.copy2(latest, target)
        click.echo(f"  - {target}: restaurado desde {latest.name}")
    if ACTIVE_FILE.exists():
        ACTIVE_FILE.unlink()
    click.echo("\nactivo: <ninguno>. Reabrí la sesión.")


@cli.command("new")
@click.argument("name")
@click.option("--from", "from_", default=None, help="Profile base para copiar (default: el activo, sino full).")
def cmd_new(name: str, from_: str | None):
    """Crea un profile nuevo a partir de otro."""
    base = from_ or _active_name() or "full"
    src = _read_profile(base)
    src["name"] = name
    src["description"] = f"Derived from {base}. Editar a mano."
    dst = PROFILES_DIR / f"{name}.json"
    if dst.exists():
        click.echo(f"profile '{name}' ya existe", err=True)
        sys.exit(1)
    _save_json(dst, src)
    click.echo(f"creado: {dst}")


@cli.command("wrap", context_settings={"ignore_unknown_options": True, "allow_extra_args": True})
@click.argument("name")
@click.argument("command", nargs=-1, type=click.UNPROCESSED, required=True)
def cmd_wrap(name: str, command: tuple[str, ...]):
    """Aplica un profile, corre un comando, y restaura el profile previo.

    Útil para correr UN comando con un set distinto de MCPs/tools sin
    switchear permanentemente. Ej:

        rag-harness wrap rag-only -- claude --print "explicame X"

    Limitación: solo afecta procesos NUEVOS que arranquen mientras el
    wrap está activo (ej. una sesión recién lanzada de Claude Code).
    Sesiones ya abiertas no ven el cambio — su harness se compiló al boot.
    """
    import subprocess

    if not command:
        click.echo("falta el comando a ejecutar después del profile", err=True)
        sys.exit(2)

    previous = _active_name()
    click.echo(f"[wrap] profile previo: {previous or '<ninguno>'}")
    click.echo(f"[wrap] activando '{name}' temporalmente…")

    profile = _read_profile(name)
    inventory = _read_inventory()
    mcp_section = _build_mcp_section(profile, inventory)
    inventory_keys = set(inventory.keys())
    _apply_to_target(CLAUDE_CONFIG, mcp_section, inventory_keys, dry_run=False)
    _apply_to_target(DEVIN_CONFIG, mcp_section, inventory_keys, dry_run=False)
    ACTIVE_FILE.write_text(name + "\n")

    try:
        click.echo(f"[wrap] ejecutando: {' '.join(command)}")
        result = subprocess.run(list(command))
        exit_code = result.returncode
    finally:
        click.echo(f"[wrap] restaurando profile previo: {previous or '<ninguno>'}")
        # Si había profile previo, lo re-aplicamos (estado consistente).
        # Si NO había, aplicamos `full` para dejar el estado equivalente
        # a "harness sin tocar" — más predecible que un restore desde
        # backup, que puede venir de una corrida anterior.
        target_name = previous if previous and (PROFILES_DIR / f"{previous}.json").exists() else "full"
        target_profile = _read_profile(target_name)
        target_section = _build_mcp_section(target_profile, inventory)
        _apply_to_target(CLAUDE_CONFIG, target_section, inventory_keys, dry_run=False)
        _apply_to_target(DEVIN_CONFIG, target_section, inventory_keys, dry_run=False)
        if previous:
            ACTIVE_FILE.write_text(previous + "\n")
        else:
            if ACTIVE_FILE.exists():
                ACTIVE_FILE.unlink()
    sys.exit(exit_code)


# ── Estimación de costo de tokens ────────────────────────────────────────────
# Aproximación pragmática: contamos chars del JSON descriptor de cada MCP
# server entry + chars de docstrings/firmas de las tools del MCP propio.
# Para MCPs externos no podemos invocar `tools/list` sin hacer un handshake
# stdio completo — usamos un estimate fijo por MCP basado en bytes del
# `command`/`args`/`env`. Tokens ≈ chars / 4 (rule of thumb GPT/Claude).

def _estimate_mcp_descriptor_tokens(entry: dict) -> int:
    """Tokens aproximados del descriptor del MCP server (sin tools)."""
    s = json.dumps(entry, separators=(",", ":"))
    return max(50, len(s) // 4)


def _estimate_obsidian_rag_tools_tokens(profile: dict) -> tuple[int, int]:
    """Tokens aproximados de las tools del MCP de obsidian-rag.

    Devuelve (tokens_total, tools_count). Lee `mcp_server.py` y parsea
    los `def rag_*` con sus docstrings; si el profile define
    `rag_mcp_tools`, filtra; si define `rag_mcp_terse=true`, recorta el
    docstring al primer párrafo antes de contar.
    """
    import re as _re
    repo_root = ROOT.parent.parent
    src = repo_root / "mcp_server.py"
    if not src.exists():
        return (0, 0)
    text = src.read_text()
    # Match "def rag_<name>(...)<...>: ... <docstring> ..."
    pat = _re.compile(
        r'^def (rag_\w+)\([^)]*\)[^:]*:\s*\n\s*"""(.*?)"""',
        _re.DOTALL | _re.MULTILINE,
    )
    allowed = set(profile.get("rag_mcp_tools") or [])
    terse = bool(profile.get("rag_mcp_terse"))

    total_chars = 0
    count = 0
    for m in pat.finditer(text):
        fn_name = m.group(1)
        short = fn_name[4:]
        if allowed and fn_name not in allowed and short not in allowed:
            continue
        doc = m.group(2).strip()
        if terse:
            doc = doc.split("\n\n", 1)[0].strip()
        # Aproximación: nombre + signature + docstring
        descriptor = f"{fn_name}: {doc}"
        total_chars += len(descriptor)
        count += 1
    return (total_chars // 4, count)


@cli.command("cost")
@click.option("--profile", "-p", "profile_name", default=None,
              help="Profile a estimar (default: el activo).")
def cmd_cost(profile_name: str | None):
    """Estima los tokens que el profile inyecta al system prompt.

    Aproximación grosera (chars/4). Útil para comparar profiles entre sí,
    no como número absoluto exacto. Para tools del MCP de obsidian-rag
    parseamos `mcp_server.py` (precisa). Para los otros MCPs estimamos
    el descriptor del entry — NO contamos las tools que cada MCP expone
    porque eso requeriría hacer un handshake stdio con cada uno.
    """
    if profile_name:
        profile = _read_profile(profile_name)
    else:
        active = _active_name()
        profile = _read_profile(active) if active else _read_profile("full")

    inventory = _read_inventory()

    # Para comparar, calculamos siempre el costo de TODOS los profiles
    profiles_data = []
    for p_path in _list_profiles():
        p = _load_json(p_path)
        section = _build_mcp_section(p, inventory)

        mcp_descriptor_tokens = sum(
            _estimate_mcp_descriptor_tokens(entry)
            for entry in section.values()
        )
        rag_tokens, rag_tool_count = _estimate_obsidian_rag_tools_tokens(p)
        # Estimate ~150 tokens/tool para MCPs externos (rough avg)
        external_mcps = [k for k in section.keys() if k != "obsidian-rag"]
        external_tools_estimate = len(external_mcps) * 5 * 150  # ~5 tools avg, ~150 tk c/u

        total = mcp_descriptor_tokens + rag_tokens + external_tools_estimate
        profiles_data.append({
            "name": p["name"],
            "mcps": len(section),
            "rag_tools": rag_tool_count,
            "tokens": total,
            "active": p["name"] == profile["name"],
        })

    # Imprimir tabla
    full_total = next((p["tokens"] for p in profiles_data if p["name"] == "full"), None)
    click.echo(f"{'profile':<14} {'mcps':>5} {'rag-tools':>10} {'tokens_est':>12}  {'delta_vs_full':>16}")
    click.echo("-" * 64)
    for p in sorted(profiles_data, key=lambda x: x["tokens"], reverse=True):
        marker = " *" if p["active"] else "  "
        delta = ""
        if full_total and p["name"] != "full":
            d = p["tokens"] - full_total
            pct = (100 * d) // full_total if full_total else 0
            delta = f"{d:+,} ({pct:+d}%)"
        click.echo(
            f"{marker} {p['name']:<11} {p['mcps']:>5} {p['rag_tools']:>10} "
            f"{p['tokens']:>12,}  {delta:>16}"
        )
    click.echo("\nNota: estimación grosera (chars/4). Útil para comparar profiles.")
    click.echo("Tools de MCPs externos (github, playwright, etc.) usan estimate de 5 tools × 150 tokens.")


# ── Watch daemon — re-aplica el profile si los configs son pisados ──────────
# Caso de uso: Claude Code (u otra herramienta) regenera ~/.claude.json y
# pisa nuestro profile. Con el watcher corriendo, detectamos el cambio y
# re-aplicamos en segundos.
#
# Implementación: polling de mtime cada `--interval` segundos (default 10).
# Cuando detectamos cambio, comparamos el `mcpServers` actual con el que el
# profile activo produciría — si difieren, re-aplicamos. Para evitar loops
# (nuestra propia escritura cambia el mtime), guardamos un hash del contenido
# que escribimos y lo comparamos antes de re-aplicar.

import hashlib


def _mcp_section_hash(section: dict) -> str:
    s = json.dumps(section, sort_keys=True, separators=(",", ":"))
    return hashlib.sha1(s.encode()).hexdigest()


@cli.command("watch")
@click.option("--interval", type=float, default=10.0, help="Segundos entre polls (default 10).")
@click.option("--once", is_flag=True, help="Hacer 1 ciclo y salir (para testing).")
def cmd_watch(interval: float, once: bool):
    """Daemon que re-aplica el profile activo si los configs son pisados.

    Lee `.active` al arrancar y en cada ciclo. Si no hay profile activo,
    duerme y vuelve a chequear (no aborta). Loggea al stdout — útil para
    LaunchAgent que captura StandardOutPath.
    """
    import time as _time

    inventory = _read_inventory()
    inventory_keys = set(inventory.keys())

    last_mtime = {p: 0.0 for p in (CLAUDE_CONFIG, DEVIN_CONFIG)}
    last_hash = {p: "" for p in (CLAUDE_CONFIG, DEVIN_CONFIG)}

    click.echo(f"[watch] iniciando — interval={interval}s")
    while True:
        active = _active_name()
        if not active:
            click.echo("[watch] no hay profile activo — durmiendo")
            if once:
                return
            _time.sleep(interval)
            continue

        try:
            profile = _read_profile(active)
        except SystemExit:
            click.echo(f"[watch] profile '{active}' no se puede leer — durmiendo")
            if once:
                return
            _time.sleep(interval)
            continue

        expected = _build_mcp_section(profile, inventory)
        expected_hash = _mcp_section_hash(expected)

        for target in (CLAUDE_CONFIG, DEVIN_CONFIG):
            if not target.exists():
                continue
            mtime = target.stat().st_mtime
            if mtime == last_mtime[target]:
                continue
            last_mtime[target] = mtime

            data = _load_json(target)
            current = dict(data.get("mcpServers") or {})
            # Solo comparamos los keys del inventory (lo que nosotros gestionamos)
            current_managed = {k: v for k, v in current.items() if k in inventory_keys}
            current_hash = _mcp_section_hash(current_managed)

            if current_hash == last_hash[target]:
                # Ya escribimos esto antes — no es drift, es nuestro propio write
                continue

            if current_hash == expected_hash:
                # Coincide con lo que el profile pide — todo bien, nada que hacer
                last_hash[target] = current_hash
                continue

            # Drift detectado — re-aplicar
            click.echo(f"[watch] drift en {target.name} — re-aplicando '{active}'")
            untouched = {k: v for k, v in current.items() if k not in inventory_keys}
            new_section = dict(untouched)
            new_section.update(expected)
            data["mcpServers"] = new_section
            _save_json(target, data)
            last_mtime[target] = target.stat().st_mtime
            last_hash[target] = expected_hash

        if once:
            return
        _time.sleep(interval)


_PLIST_LABEL = "com.fer.rag-harness-watcher"


def _plist_path() -> Path:
    return Path.home() / "Library" / "LaunchAgents" / f"{_PLIST_LABEL}.plist"


@cli.command("watch-install")
@click.option("--interval", type=float, default=10.0)
def cmd_watch_install(interval: float):
    """Instala un LaunchAgent que corre `rag-harness watch` al login."""
    plist = _plist_path()
    plist.parent.mkdir(parents=True, exist_ok=True)
    bin_path = Path(__file__).resolve()
    log_dir = Path.home() / ".local" / "share" / "rag-harness"
    log_dir.mkdir(parents=True, exist_ok=True)

    # `uv run --script` con metadata PEP 723 inline. launchd no respeta de
    # forma confiable el shebang `#!/usr/bin/env -S uv run ...` cuando el
    # script está en ProgramArguments[0] — termina lanzándolo con system
    # python que no tiene `click` y el daemon rebota en loop. Invocamos uv
    # directo para evitar ese rabbit hole.
    uv_path = ""
    for candidate in (
        Path.home() / ".local" / "bin" / "uv",
        Path("/opt/homebrew/bin/uv"),
        Path("/usr/local/bin/uv"),
    ):
        if candidate.exists():
            uv_path = str(candidate)
            break
    if not uv_path:
        click.echo("error: no encuentro `uv` en ~/.local/bin ni homebrew", err=True)
        sys.exit(1)

    content = f"""<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>{_PLIST_LABEL}</string>
  <key>ProgramArguments</key>
  <array>
    <string>{uv_path}</string>
    <string>run</string>
    <string>--quiet</string>
    <string>--script</string>
    <string>{bin_path}</string>
    <string>watch</string>
    <string>--interval</string>
    <string>{interval}</string>
  </array>
  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>
  <key>StandardOutPath</key>
  <string>{log_dir}/watcher.out.log</string>
  <key>StandardErrorPath</key>
  <string>{log_dir}/watcher.err.log</string>
  <key>EnvironmentVariables</key>
  <dict>
    <key>PATH</key>
    <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/Users/{Path.home().name}/.local/bin</string>
  </dict>
</dict>
</plist>
"""
    plist.write_text(content)
    click.echo(f"plist escrito: {plist}")
    # Bootstrap (carga + arranca)
    import subprocess
    subprocess.run(["launchctl", "bootout", f"gui/{os.getuid()}", str(plist)], check=False)
    r = subprocess.run(
        ["launchctl", "bootstrap", f"gui/{os.getuid()}", str(plist)],
        capture_output=True, text=True,
    )
    if r.returncode != 0:
        click.echo(f"warning: launchctl bootstrap falló: {r.stderr}", err=True)
    else:
        click.echo(f"daemon levantado. logs en {log_dir}/watcher.{{out,err}}.log")


@cli.command("watch-uninstall")
def cmd_watch_uninstall():
    """Desinstala el LaunchAgent del watcher."""
    import subprocess
    plist = _plist_path()
    if plist.exists():
        subprocess.run(["launchctl", "bootout", f"gui/{os.getuid()}", str(plist)], check=False)
        plist.unlink()
        click.echo(f"plist removido: {plist}")
    else:
        click.echo("no había plist instalado")


# ── Default profile + suggest ────────────────────────────────────────────────

DEFAULT_FILE = ROOT / ".default"


@cli.command("default")
@click.argument("name", required=False)
@click.option("--clear", is_flag=True, help="Borrar el default.")
@click.option("--apply", "do_apply", is_flag=True, help="Aplicar el default ahora.")
def cmd_default(name: str | None, clear: bool, do_apply: bool):
    """Set / show / clear / apply el profile default.

    `default <name>` setea, `default` solo muestra, `default --clear` borra,
    `default --apply` aplica el default actual (equivalente a `use <default>`).
    """
    if clear:
        if DEFAULT_FILE.exists():
            DEFAULT_FILE.unlink()
        click.echo("default removido")
        return

    if do_apply:
        if not DEFAULT_FILE.exists():
            click.echo("no hay default seteado", err=True)
            sys.exit(1)
        cmd_use.callback(DEFAULT_FILE.read_text().strip(), False)  # type: ignore[attr-defined]
        return

    if name:
        # Validar que el profile existe
        _read_profile(name)
        DEFAULT_FILE.write_text(name + "\n")
        click.echo(f"default seteado: {name}")
        click.echo("→ aplicalo cuando quieras con `rag-harness default --apply`")
        return

    if DEFAULT_FILE.exists():
        click.echo(f"default actual: {DEFAULT_FILE.read_text().strip()}")
    else:
        click.echo("no hay default seteado")


def _gather_signals() -> dict:
    """Recolecta señales del entorno: cwd, history, git repo.

    Devuelve dict con campos primitivos para que las reglas de scoring
    sean fáciles de testear y extender.
    """
    import subprocess
    cwd = str(Path.cwd())

    # Shell history
    history_text = ""
    for h in (Path.home() / ".zsh_history", Path.home() / ".bash_history"):
        if h.exists():
            try:
                history_text = h.read_text(errors="ignore")[-50000:]
                break
            except OSError:
                continue

    # Git repo
    git_root = ""
    try:
        r = subprocess.run(
            ["git", "rev-parse", "--show-toplevel"],
            capture_output=True, text=True, cwd=cwd,
        )
        if r.returncode == 0:
            git_root = r.stdout.strip()
    except FileNotFoundError:
        pass

    return {
        "cwd": cwd,
        "history_lower": history_text.lower(),
        "git_root": git_root,
        "in_obsidian_rag": "obsidian-rag" in cwd,
        "git_repo_name": Path(git_root).name if git_root else "",
    }


# Reglas de scoring: cada regla devuelve (puntos, razón) si aplica, None si no.
# Los puntos se acumulan sobre el profile target. El profile con más puntos
# gana. Si empate, tie-breaker = orden alfabético del profile (estable).
def _scoring_rules() -> list[tuple[str, callable]]:
    """Lista de (profile_target, predicate_fn). predicate_fn devuelve
    `(puntos, razón)` o `None`. La idea es que sea trivial agregar reglas
    nuevas — cada una es independiente.
    """
    def _r_playwright(s):
        h, c = s["history_lower"], s["cwd"]
        if "playwright" in h:
            return (4, "history reciente con playwright")
        if "/web/" in c or c.endswith("/web"):
            return (3, "cwd dentro de /web/")
        return None

    def _r_comms(s):
        h = s["history_lower"]
        hits = [t for t in ("wa-tasks", "whatsapp", "gmail-send", "rag morning", "rag today")
                if t in h]
        if hits:
            return (len(hits) * 2, f"history con {hits}")
        return None

    def _r_writing(s):
        h = s["history_lower"]
        hits = [t for t in ("rag capture", "rag save", "rag inbox", "rag file")
                if t in h]
        if hits:
            return (len(hits) * 2, f"history con {hits}")
        return None

    def _r_rag_only_history(s):
        h = s["history_lower"]
        hits = [t for t in ("rag query", "rag chat", "rag stats", "rag links")
                if t in h]
        if not hits:
            return None
        # Bonus si además estás en obsidian-rag
        pts = len(hits) * 2 + (3 if s["in_obsidian_rag"] else 0)
        return (pts, f"history con {hits}" + (" + cwd obsidian-rag" if s["in_obsidian_rag"] else ""))

    def _r_dev_other_repo(s):
        if s["git_root"] and "obsidian-rag" not in s["git_root"]:
            return (3, f"git repo = {s['git_repo_name']} (no obsidian-rag)")
        return None

    def _r_rag_only_cwd(s):
        # Señal de fallback: estar en obsidian-rag sin nada más
        if s["in_obsidian_rag"]:
            return (1, "cwd contiene obsidian-rag (señal débil)")
        return None

    return [
        ("debug-web", _r_playwright),
        ("comms",     _r_comms),
        ("writing",   _r_writing),
        ("rag-only",  _r_rag_only_history),
        ("dev",       _r_dev_other_repo),
        ("rag-only",  _r_rag_only_cwd),
    ]


def _suggest_profile() -> tuple[str, dict[str, int], dict[str, list[str]]]:
    """Devuelve (profile_top, scores_por_profile, razones_por_profile).

    Si todos los scores son 0, fallback a `rag-only`.
    """
    signals = _gather_signals()
    scores: dict[str, int] = {}
    reasons: dict[str, list[str]] = {}
    for target, rule in _scoring_rules():
        result = rule(signals)
        if result is None:
            continue
        pts, reason = result
        scores[target] = scores.get(target, 0) + pts
        reasons.setdefault(target, []).append(f"+{pts} {reason}")

    if not scores:
        return ("rag-only", {"rag-only": 0}, {"rag-only": ["fallback (sin señales)"]})

    # Pick top: max score, tie-breaker = nombre alfabético (estable)
    top = max(scores.items(), key=lambda kv: (kv[1], -ord(kv[0][0])))
    return (top[0], scores, reasons)


@cli.command("suggest")
@click.option("--apply", "do_apply", is_flag=True, help="Aplicar el profile sugerido.")
@click.option("--all", "show_all", is_flag=True, help="Mostrar el ranking completo, no solo el top.")
def cmd_suggest(do_apply: bool, show_all: bool):
    """Recomienda un profile basado en cwd + shell history + git repo.

    Scoring ponderado: cada señal aporta puntos al profile correspondiente.
    El profile con más puntos gana. Útil para ver POR QUÉ se sugiere algo
    y agregar reglas nuevas según tu workflow.
    """
    name, scores, reasons = _suggest_profile()
    click.echo(f"sugerencia: {name} (score: {scores.get(name, 0)})")
    click.echo("razones:")
    for r in reasons.get(name, []):
        click.echo(f"  {r}")

    if show_all and len(scores) > 1:
        click.echo("\nranking completo:")
        for p, sc in sorted(scores.items(), key=lambda kv: kv[1], reverse=True):
            click.echo(f"  {p:<12} score={sc}")
            for r in reasons.get(p, []):
                click.echo(f"    {r}")

    if do_apply:
        click.echo()
        cmd_use.callback(name, False)  # type: ignore[attr-defined]


if __name__ == "__main__":
    cli()
